NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Neon (see MIGRATION_PLAN.md) — required once any app/api/* route is hit.
DATABASE_URL=postgres://user:password@host/dbname
NEON_AUTH_BASE_URL=https://your-neon-auth-domain
# Any random 32+ character string, generated once — not tied to any account.
NEON_AUTH_COOKIE_SECRET=

# Server-side only; never exposed to the browser. Mint a fresh key here —
# do not reuse the one configured on the Supabase ai-chat Edge Function.
ANTHROPIC_API_KEY=
